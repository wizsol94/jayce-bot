{
  "manifest_version": 3,
  "name": "Jayce DexScreener Collector",
  "version": "1.0.0",
  "description": "Captures DexScreener rotation data for Jayce scanner",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://dexscreener.com/*",
    "http://104.236.105.118:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
